# NeMo container for diarization + speaker ID + SED stages.
# CUDA 12.4 compatible.
#
# Build:
#   docker build -t curator-nemo-stages -f tutorials/audio/hifi_pipeline/Dockerfile.nemo .
#
# Run:
#   docker run --gpus all --ipc=host --shm-size=8g \
#     -v /data:/data -v /models:/models \
#     curator-nemo-stages \
#     --input_manifest /data/manifest.jsonl \
#     --stages sed,sed_post,diarize,embed,cluster

FROM pytorch/pytorch:2.6.0-cuda12.6-cudnn9-runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl libsndfile1 ffmpeg && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip

WORKDIR /opt/Curator
COPY pyproject.toml /opt/Curator/
COPY nemo_curator/__init__.py nemo_curator/package_info.py /opt/Curator/nemo_curator/
RUN pip install --no-cache-dir .

COPY . /opt/Curator
RUN pip install --no-cache-dir . && \
    pip install --no-cache-dir \
    'nemo_toolkit[asr]' \
    torchlibrosa librosa soundfile pyyaml \
    huggingface_hub openai aistore && \
    pip install --no-cache-dir \
    'torch==2.6.0' 'torchaudio==2.6.0' 'torchvision==0.21.0'

# Bake in model checkpoints:
#   PANNs CNN14 (~313MB) for SED
#   Sortformer (~500MB) for diarization
#   TitaNet-Large (~100MB) for speaker embeddings
RUN mkdir -p /opt/checkpoints && \
    curl -fsSL -o /opt/checkpoints/Cnn14_DecisionLevelMax.pth \
        'https://zenodo.org/record/3987831/files/Cnn14_DecisionLevelMax_mAP%3D0.385.pth'

ENV HF_HOME=/opt/hf_cache
RUN python -c "from huggingface_hub import snapshot_download; \
    snapshot_download(repo_id='nvidia/diar_streaming_sortformer_4spk-v2')"

RUN python -c "import nemo.collections.asr as nemo_asr; \
    nemo_asr.models.EncDecSpeakerLabelModel.from_pretrained('titanet_large')"

RUN ls -lh /opt/checkpoints/ && du -sh /opt/hf_cache /root/.cache 2>/dev/null || true

ENV PANN_CKPT=/opt/checkpoints/Cnn14_DecisionLevelMax.pth
ENV PYTHONPATH=/opt/Curator
ENTRYPOINT ["python", "/opt/Curator/tutorials/audio/hifi_pipeline/run_pipeline.py"]
